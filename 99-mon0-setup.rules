# 99-mon0-setup.rules — trigger mon0-setup.service when the sniffer adapter appears.
#
# This rule fires the moment the kernel/udev enumerates the interface, which is
# the correct trigger for USB adapters that appear after systemd has already run
# time-based services.
#
# Install:
#   sudo cp 99-mon0-setup.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules
#
# To test without rebooting (simulates the add event):
#   sudo udevadm trigger --action=add --subsystem-match=net --attr-match=ifindex=$(cat /sys/class/net/wlx289401bca7bd/ifindex)

ACTION=="add", SUBSYSTEM=="net", KERNEL=="wlx289401bca7bd", \
    TAG+="systemd", ENV{SYSTEMD_WANTS}="mon0-setup.service"
